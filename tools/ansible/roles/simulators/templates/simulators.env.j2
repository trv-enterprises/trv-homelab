# Simulators environment configuration
# Managed by Ansible - do not edit manually

# ts-store configuration
TSSTORE_IMAGE={{ tsstore_image }}
TSSTORE_INTERNAL_PORT={{ tsstore_internal_port }}
TSSTORE_PORT={{ tsstore_port }}
TSSTORE_ADMIN_KEY={{ simulators_tsstore_admin_key }}
TSSTORE_API_KEY={{ simulators_tsstore_api_key }}

# Data writer configuration
DATA_WRITER_INTERVAL_MS={{ data_writer_interval_ms }}
DATA_WRITER_NOISE={{ data_writer_noise }}
DATA_WRITER_ANOMALY_RATE={{ data_writer_anomaly_rate }}

# Database seeder configuration
NUM_SENSORS={{ db_num_sensors }}
DAYS_BACK={{ db_days_back }}
INTERVAL_SECONDS={{ db_interval_seconds }}

# WebSocket simulator configuration
WS_INTERVAL_MS={{ ws_interval_ms }}
WS_NUM_SENSORS={{ ws_num_sensors }}
WS_ENABLE_NOISE={{ ws_enable_noise }}
WS_ANOMALY_RATE={{ ws_anomaly_rate }}

# REST API simulator configuration
API_BUFFER_SIZE={{ api_buffer_size }}
API_GENERATE_MS={{ api_generate_ms }}
