# Dashboard deployment - managed by Ansible
# Do not edit manually

services:
  caddy:
    image: {{ dashboard_client_image }}:{{ dashboard_version }}
    ports:
      - "80:80"
{% if dashboard_enable_https | default(false) %}
      - "443:443"
{% endif %}
    environment:
      - DOMAIN={{ dashboard_domain }}
{% if dashboard_enable_https | default(false) and dashboard_caddy_tls_directive | default('') %}
      # Env-gated TLS cert source (outpost-client >= build 1964 / commit 5deb552
      # expands {$CADDY_TLS_DIRECTIVE} in its Caddyfile). For the Tailscale path
      # this is `tls { get_certificate tailscale }`, which makes Caddy pull a
      # publicly-trusted Let's Encrypt cert for the .ts.net DOMAIN from the local
      # tailscaled over the socket mounted below. Empty/unset => unchanged.
      - CADDY_TLS_DIRECTIVE={{ dashboard_caddy_tls_directive }}
{% endif %}
    volumes:
      - caddy_data:/data
      - caddy_config:/config
{% if dashboard_enable_https | default(false) and dashboard_caddy_tls_directive | default('') %}
      # tailscaled socket from the LXC host, so Caddy's tailscale cert module can
      # request the cert at handshake time. The LXC (104) is itself a tailnet
      # node, so the socket exists at this path inside the container's host.
      - /var/run/tailscale/tailscaled.sock:/var/run/tailscale/tailscaled.sock
{% endif %}
    depends_on:
      server:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:2019/config/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  server:
    image: {{ dashboard_server_image }}:{{ dashboard_version }}
    ports:
      - "3001:3001"
    environment:
      # CORS allowlist. The client Caddy proxies /api/* to server:3001 so the
      # browser sees a single same-origin host, but the server still enforces
      # this list against the request Origin. When HTTPS is on (pre-prod), the
      # browser's Origin becomes https://<host>, which must be allowlisted or
      # cross-origin requests (incl. Clerk flows) are rejected. We append the
      # https:// variants rather than replace, so the http:// entries stay valid.
      - DASHBOARD_CORS_ORIGINS=http://<dashboard-lan-ip>,http://{{ lan_ip | default(ansible_host) }}{{ (',https://' ~ ansible_host) if (dashboard_enable_https | default(false)) else '' }}{{ (',https://' ~ lan_ip) if (dashboard_enable_https | default(false)) and (lan_ip is defined) else '' }}
      - DASHBOARD_SERVER_MODE=release
      - DASHBOARD_SERVER_HOST=0.0.0.0
      - DASHBOARD_MONGODB_URI=mongodb://mongodb:27017
      - DASHBOARD_MONGODB_DATABASE=dashboard
      - DASHBOARD_LLM_API_KEY={{ anthropic_api_key | default('') }}
      # In-app AI key (Component AI agent + Dashboard Assistant). Sourced from
      # the deploy-time env ASSISTANT_ANTHROPIC_API_KEY (see role vars). This is
      # the path used to enable the AIs on prod + pre-prod.
      - ASSISTANT_ANTHROPIC_API_KEY={{ assistant_anthropic_api_key }}
      # Address ts-store dials back to for push-mode streaming callbacks.
      - DASHBOARD_HOST={{ lan_ip | default(ansible_host) }}:3001
      # Server-wide gate that lets per-connection insecure_skip_verify take effect.
      # Required for api.rest connections to self-signed endpoints (e.g. Proxmox).
      - DASHBOARD_API_ALLOW_INSECURE_TLS={{ dashboard_api_allow_insecure_tls | default('false') }}
      # Clerk identity provider. Setting CLERK_SECRET_KEY is the soft
      # switch for Clerk mode — leave empty to keep the deployment on
      # API-key + legacy auth (the homelab LXC pattern).
      - CLERK_SECRET_KEY={{ clerk_secret_key | default('') }}
      - CLERK_PUBLISHABLE_KEY={{ clerk_publishable_key | default('') }}
      # Legacy GUID auth (X-User-ID header, ?user_id= query).
      # Default false in the dashboard server itself; this homelab
      # role explicitly enables it because the kiosk URL bookmarks
      # and any admin re-keying flow rely on ?user_id= URLs.
      # The dashboard-prod role does NOT set this (keeps it false),
      # which is the right posture for any deployment fronted by
      # a real IdP like Clerk.
      - DASHBOARD_AUTH_ALLOW_LEGACY_GUID={{ dashboard_auth_allow_legacy_guid | default('true') }}
    depends_on:
      mongodb:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:3001/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  mongodb:
    image: mongo:7
    ports:
      - "27017:27017"
    volumes:
      - mongodb_data:/data/db
    healthcheck:
      test: echo 'db.runCommand("ping").ok' | mongosh --quiet
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

volumes:
  mongodb_data:
  caddy_data:
  caddy_config:
