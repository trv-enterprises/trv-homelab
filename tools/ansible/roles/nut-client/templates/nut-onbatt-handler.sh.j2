#!/bin/bash
# Managed by Ansible - do not edit manually
#
# NUT NOTIFYCMD handler for a netclient: schedules a delayed local
# shutdown when the primary reports the UPS is on battery, and cancels
# it if line power returns.

set -euo pipefail

MSG="${1:-}"
LOG_TAG="nut-onbatt"
SHUTDOWN_MINUTES={{ (nut_shutdown_ontime_seconds / 60) | int }}

log() {
    logger -t "$LOG_TAG" "$@"
}

case "${NOTIFYTYPE:-}" in
    ONBATT)
        log "UPS on battery: scheduling shutdown in $SHUTDOWN_MINUTES minutes"
        # upsmon runs NOTIFYCMD as the non-privileged 'nut' user. We need
        # root to talk to systemd-logind, so invoke shutdown via sudo.
        # Sudoers grant is deployed by the nut-client role.
        sudo -n /sbin/shutdown -P +${SHUTDOWN_MINUTES} "NUT: UPS on battery, shutting down in ${SHUTDOWN_MINUTES} minutes" 2>&1 | logger -t "$LOG_TAG" || log "sudo shutdown failed"
        ;;
    ONLINE)
        log "UPS back on line power: cancelling pending shutdown"
        sudo -n /sbin/shutdown -c "NUT: line power restored" 2>&1 | logger -t "$LOG_TAG" || log "sudo shutdown -c failed"
        ;;
    LOWBATT)
        log "UPS low battery: immediate shutdown handled by upsmon SHUTDOWNCMD"
        ;;
    *)
        log "Unhandled NOTIFYTYPE: ${NOTIFYTYPE:-<unset>} msg=$MSG"
        ;;
esac
