all:
  children:
    hub:
      hosts:
        srv-001:
          ansible_host: <tailscale-ip>
          lan_ip: null
          role: Hub server (ts-store, stats)
        srv-002:
          ansible_host: <tailscale-ip>
          lan_ip: <lan-ip>
          role: Proxmox VE host

    pis:
      hosts:
        pi-001:
          ansible_host: <tailscale-ip>
          lan_ip: <lan-ip>
          role: ts-store + SenseHat
        pi-002:
          ansible_host: <tailscale-ip>
          role: Mosquitto + ts-store + Shelly

    kiosk:
      hosts:
        kiosk-001:
          ansible_host: <tailscale-ip>
          lan_ip: <lan-ip>
          role: Voice-controlled kiosk

    apps:
      hosts:
        dashboard:
          ansible_host: <tailscale-ip>
          lan_ip: <lan-ip>
          role: Dashboard app (LXC)
        services:
          ansible_host: <tailscale-ip>
          role: Services (LXC) - Mosquitto, Zigbee2MQTT, Homebridge
        nvr:
          ansible_host: <tailscale-ip>
          role: NVR (LXC) - Frigate, Scrypted

  vars:
    ansible_user: <user>
    ansible_ssh_common_args: '-o StrictHostKeyChecking=no -o ConnectTimeout=10'
